{
  "name": "clinical-ui-automation",
  "version": "1.0.0",
  "description": "Playwright automation framework for Clinical UI testing",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:e2e": "playwright test tests/e2e",
    "test:single": "playwright test",
    "test:single:headed": "playwright test --headed",
    "test:single:debug": "cross-env PWDEBUG=1 playwright test",
    "test:qa": "cross-env TEST_ENV=qa playwright test",
    "qa:smoke": "cross-env TEST_ENV=qa playwright test --grep @smoke",
    "qa:headed": "cross-env TEST_ENV=qa playwright test --headed",
    "qa:debug": "cross-env TEST_ENV=qa PWDEBUG=1 playwright test",
    "test:role:admin": "cross-env TEST_ROLE=admin playwright test",
    "test:role:user": "cross-env TEST_ROLE=user playwright test",
    "test:role:viewer": "cross-env TEST_ROLE=viewer playwright test",
    "qa:role:admin": "cross-env TEST_ENV=qa TEST_ROLE=admin playwright test",
    "qa:role:user": "cross-env TEST_ENV=qa TEST_ROLE=user playwright test",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "setup:local": "cp .env.example .env.local && echo 'Please update .env.local with your credentials'",
    "playwright:install": "playwright install",
    "validate:env": "node -e \"require('dotenv').config({ path: '.env.local' }); console.log('Environment loaded successfully');\"",
    "test:ui": "playwright test --ui",
    "test:ui:qa": "cross-env TEST_ENV=qa playwright test --ui",
    "test:inspect": "cross-env PWDEBUG=1 playwright test",
    "test:trace": "playwright test --trace on --headed",
    "test:slow": "playwright test --headed --slow-mo=1000",
    "test:video": "cross-env VIDEO_ON_FAILURE=true playwright test --headed",
    "test:screenshot": "cross-env SCREENSHOT_ON_FAILURE=true playwright test --headed",
    "show:trace": "playwright show-trace",
    "debug:billing": "cross-env PWDEBUG=1 playwright test tests/Hope/billing-patient-search.spec.ts",
    "ui:billing": "playwright test tests/Hope/billing-patient-search.spec.ts --ui"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "e2e",
    "clinical"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@currents/playwright": "^1.17.1",
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.40.1",
    "@types/node": "^20.10.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "typescript": "^5.3.3"
  }
}
