# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
# Which environment to test (dev, qa, staging, prod)
TEST_ENV=qa

# ============================================
# TENANT CONFIGURATION
# ============================================
# Which tenant to use for credentials and test data
# Available tenants: cth, integrum
TENANT=cth

# ============================================
# ENVIRONMENT URLs
# ============================================
QA_URL=https://clinical.qa1.curantissolutions.com

# ============================================
# CREDENTIALS
# ============================================
# Credentials follow the naming convention:
# {ENVIRONMENT}_{TENANT}_{ROLE}_USERNAME
# {ENVIRONMENT}_{TENANT}_{ROLE}_PASSWORD
#
# Where:
#   ENVIRONMENT = QA, STAGING, PROD, DEV
#   TENANT = CTH, INTEGRUM (optional - can use env-only credentials)
#   ROLE = MD, RN, SW, HA, NP (optional - can use tenant-level credentials)
#
# Add your actual credentials to .env.local (never commit that file)
#
# Examples:
# QA_USERNAME=your_default_qa_username
# QA_PASSWORD=your_default_qa_password
#
# QA_CTH_USERNAME=your_cth_username
# QA_CTH_PASSWORD=your_cth_password
# QA_CTH_MD_USERNAME=your_cth_md_username
# QA_CTH_MD_PASSWORD=your_cth_md_password
# QA_CTH_RN_USERNAME=your_cth_rn_username
# QA_CTH_RN_PASSWORD=your_cth_rn_password
# QA_CTH_SW_USERNAME=your_cth_sw_username
# QA_CTH_SW_PASSWORD=your_cth_sw_password
# QA_CTH_HA_USERNAME=your_cth_ha_username
# QA_CTH_HA_PASSWORD=your_cth_ha_password
#
# QA_INTEGRUM_USERNAME=your_integrum_username
# QA_INTEGRUM_PASSWORD=your_integrum_password
# QA_INTEGRUM_MD_USERNAME=your_integrum_md_username
# QA_INTEGRUM_MD_PASSWORD=your_integrum_md_password
# QA_INTEGRUM_RN_USERNAME=your_integrum_rn_username
# QA_INTEGRUM_RN_PASSWORD=your_integrum_rn_password

# ============================================
# TEST CONFIGURATION
# ============================================
HEADLESS=true           # Run tests without browser UI (faster)
WORKERS=1               # Number of parallel workers (set to 1 for sequential execution)
TIMEOUT=30000          # Test timeout in milliseconds
RETRIES=1              # Number of retries for failed tests
SLOWMO=0               # Slow down actions by X milliseconds (0 = disabled)

# ============================================
# REPORTING
# ============================================
SHOW_REPORT=false               # Automatically open HTML report after test run
SCREENSHOT_ON_FAILURE=true      # Capture screenshot when test fails
VIDEO_ON_FAILURE=false         # Record video for failed tests

# ============================================
# TEST DATA (DEPRECATED - Now in config/test-data.ts)
# ============================================
# The following variables have been moved to config/test-data.ts for better organization:
# - Physician names (use TestDataManager.getPhysician())
# - Care team names (use TestDataManager.getCareTeam())
# - RN signature names (use TestDataManager.getRNSign())
#
# These are now configured per environment and tenant in config/test-data.ts
# DEPRECATED: TEST_PHYSICIAN
# DEPRECATED: QA_PHYSICIAN
# DEPRECATED: TEST_CARE_TEAM
# DEPRECATED: QA_RN_SIGN